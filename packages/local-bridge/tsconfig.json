{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@cocapn/protocols": ["../protocols/src/index.ts"],
      "@cocapn/protocols/mcp": ["../protocols/src/mcp/index.ts"],
      "@cocapn/protocols/a2a": ["../protocols/src/a2a/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests"]
}
