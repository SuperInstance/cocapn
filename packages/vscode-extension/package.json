{
  "name": "cocapn-vscode",
  "displayName": "Cocapn — Your Repo Is Alive",
  "description": "The repo IS the agent. Brain, wiki, chat, and fleet status — right in your editor.",
  "version": "0.1.0",
  "publisher": "cocapn",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cocapn.start",
        "title": "Cocapn: Start"
      },
      {
        "command": "cocapn.stop",
        "title": "Cocapn: Stop"
      },
      {
        "command": "cocapn.status",
        "title": "Cocapn: Status"
      },
      {
        "command": "cocapn.chat",
        "title": "Cocapn: Chat"
      },
      {
        "command": "cocapn.setup",
        "title": "Cocapn: Setup"
      },
      {
        "command": "cocapn.refreshTree",
        "title": "Cocapn: Refresh Sidebar",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cocapn-sidebar",
          "title": "Cocapn",
          "icon": "data:image/svg+xml;base64,"
        }
      ]
    },
    "views": {
      "cocapn-sidebar": [
        {
          "id": "cocapn.tree",
          "name": "Brain"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cocapn.tree",
        "contents": "No cocapn project detected.\n[Cocapn: Setup](command:cocapn.setup)"
      }
    ]
  },
  "scripts": {
    "build": "cp src/*.js out/"
  }
}
